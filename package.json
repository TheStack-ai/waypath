{
  "name": "waypath",
  "version": "0.1.0-rc.0",
  "description": "Local-first external brain CLI for Waypath host shims and truth workflows.",
  "type": "module",
  "main": "dist/src/index.js",
  "files": [
    "dist/src/**",
    "README.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "typecheck": "node scripts/build.mjs --check",
    "test": "npm run build && node dist/tests/run-tests.js",
    "start": "npm run build && node dist/src/cli.js",
    "codex": "npm run build && node dist/src/cli.js codex --json",
    "clean": "rm -rf dist",
    "pack:release": "npm pack"
  },
  "bin": {
    "waypath": "dist/src/cli.js",
    "waypath-mcp-server": "dist/src/mcp/bin.js"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "keywords": [
    "waypath",
    "codex",
    "local-first",
    "sqlite",
    "memory",
    "cli"
  ]
}
